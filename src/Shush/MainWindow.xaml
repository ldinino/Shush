<Window x:Class="Shush.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shush"
        mc:Ignorable="d"
        Title="Shush"
        Width="380"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Icon="{StaticResource AppIcon}"
        FontFamily="Segoe UI"
        Background="#F5F6F8">
    <Grid Margin="22">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Image Source="{StaticResource AppIcon}" Width="26" Height="26" VerticalAlignment="Center" />
                <TextBlock Text="Shush" FontSize="22" FontWeight="SemiBold" Margin="10,0,0,0"
                           VerticalAlignment="Center" Foreground="#111827" />
            </StackPanel>
            <TextBlock Text="Attenuate output below what Windows allows"
                       Foreground="#6B7280" FontSize="12" Margin="0,0,0,18" />

            <!-- Live readout -->
            <Border Background="White" CornerRadius="10" Padding="0,14" Margin="0,0,0,16"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <TextBlock Text="{Binding OutputSummary}" HorizontalAlignment="Center"
                           FontSize="28" FontWeight="Bold" Foreground="#2563EB" />
            </Border>

            <!-- Attenuation slider (dB) -->
            <Slider Minimum="-60" Maximum="0"
                    Value="{Binding Decibels, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TickFrequency="6" TickPlacement="BottomRight" IsSnapToTickEnabled="False"
                    LargeChange="3" SmallChange="0.5" />
            <Grid Margin="0,2,0,16">
                <TextBlock Text="Quieter &#183; &#8722;60 dB" Foreground="#6B7280" FontSize="11" HorizontalAlignment="Left" />
                <TextBlock Text="Full &#183; 0 dB" Foreground="#6B7280" FontSize="11" HorizontalAlignment="Right" />
            </Grid>

            <!-- Mute -->
            <CheckBox Content="Mute all output" IsChecked="{Binding IsMuted}"
                      Margin="0,0,0,16" Foreground="#111827" />

            <!-- Output device -->
            <TextBlock Text="OUTPUT DEVICE" Foreground="#6B7280" FontSize="11"
                       FontWeight="SemiBold" Margin="0,0,0,6" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="DisplayName"
                          Padding="8,5" />
                <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshDevicesCommand}"
                        Margin="8,0,0,0" Padding="12,5" />
            </Grid>

            <!-- Startup -->
            <CheckBox Content="Launch at startup (minimized to tray)" IsChecked="{Binding LaunchAtStartup}"
                      Margin="0,0,0,16" Foreground="#111827" />

            <!-- Connection status -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#F59E0B" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#22C55E" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="#374151" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Footer -->
            <TextBlock Foreground="#9CA3AF" FontSize="11" TextWrapping="Wrap"
                       Text="Closing hides Shush to the tray. Right-click the tray icon to exit." />
        </StackPanel>
    </Grid>
</Window>
